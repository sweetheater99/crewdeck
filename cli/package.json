{
  "name": "crewdeck",
  "version": "0.2.7",
  "description": "Crewdeck CLI — orchestrate AI agent teams to run a business",
  "type": "module",
  "bin": {
    "crewdeck": "./dist/index.js"
  },
  "keywords": [
    "crewdeck",
    "ai",
    "agents",
    "orchestration",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paperclipai/paperclip.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/paperclipai/paperclip",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node --input-type=module -e \"import esbuild from 'esbuild'; import config from './esbuild.config.mjs'; await esbuild.build(config);\" && chmod +x dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@crewdeck/adapter-claude-local": "workspace:*",
    "@crewdeck/adapter-codex-local": "workspace:*",
    "@crewdeck/adapter-cursor-local": "workspace:*",
    "@crewdeck/adapter-opencode-local": "workspace:*",
    "@crewdeck/adapter-openclaw": "workspace:*",
    "@crewdeck/adapter-utils": "workspace:*",
    "@crewdeck/db": "workspace:*",
    "@crewdeck/server": "workspace:*",
    "@crewdeck/shared": "workspace:*",
    "drizzle-orm": "0.38.4",
    "dotenv": "^17.0.1",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
